---
import SiteLayout from '../layouts/SiteLayout.astro';
import SiteHeader from './SiteHeader.astro';
import SiteFooter from './SiteFooter.astro';
import { copy, localePath, type Locale } from '../i18n';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = copy[locale];
const bookHref = localePath(locale, '/book/');
---
<SiteLayout locale={locale} title={t.meta.title} description={t.meta.description}>
  <SiteHeader locale={locale} t={t} />
  <main id="main">
    <section class="hero section-shell">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow">{t.hero.eyebrow}</p>
        <h1>{t.hero.title.split('\n').map((line) => <span>{line}</span>)}</h1>
        <p class="hero-lead">{t.hero.lead}</p>
        <div class="button-row">
          <a class="button" href={bookHref}>{t.hero.primary}<span aria-hidden="true">↗</span></a>
          <a class="text-link" href="#about">{t.hero.secondary}<span aria-hidden="true">↓</span></a>
        </div>
      </div>
      <div class="hero-visual" data-reveal>
        <div class="hero-sun" aria-hidden="true"></div>
        <div class="portrait-frame">
          <img src="/images/arevik-portrait.webp" alt={t.hero.imageAlt} width="804" height="1200" loading="eager" fetchpriority="high" />
        </div>
        <p class="image-note"><span></span>{t.hero.note}</p>
      </div>
      <svg class="movement-line" viewBox="0 0 1400 500" preserveAspectRatio="none" aria-hidden="true">
        <path d="M-60 430C250 410 230 90 560 100s350 340 900 190" />
      </svg>
    </section>

    <section class="method section-shell" id="method">
      <div class="section-intro" data-reveal>
        <p class="eyebrow">{t.method.eyebrow}</p>
        <h2>{t.method.title}</h2>
      </div>
      <div class="method-copy" data-reveal>
        <p class="large-copy">{t.method.body}</p>
        <ol class="principles">
          {t.method.principles.map((item, index) => (
            <li>
              <span>0{index + 1}</span>
              <div><h3>{item.title}</h3><p>{item.text}</p></div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="sessions section-shell" id="sessions">
      <div class="sessions-heading" data-reveal>
        <div><p class="eyebrow">{t.sessions.eyebrow}</p><h2>{t.sessions.title}</h2></div>
        <p class="session-note"><span></span>{t.sessions.note}</p>
      </div>
      <div class="session-grid">
        <article class="session-card session-card--private" data-reveal>
          <div>
            <p class="card-kicker">{t.sessions.private.kicker}</p>
            <h3>{t.sessions.private.title}</h3>
            <p class="session-time">{t.sessions.private.time}</p>
            <p>{t.sessions.private.text}</p>
          </div>
          <a class="card-link" href={bookHref}>{t.sessions.private.cta}<span aria-hidden="true">↗</span></a>
        </article>
        <article class="session-card session-card--group" data-reveal>
          <img src="/images/side-plank.webp" alt="" width="1800" height="1208" loading="lazy" />
          <div class="session-card-content">
            <div>
              <p class="card-kicker">{t.sessions.group.kicker}</p>
              <h3>{t.sessions.group.title}</h3>
              <p class="session-time">{t.sessions.group.time}</p>
              <p>{t.sessions.group.text}</p>
            </div>
            <a class="card-link" href={bookHref}>{t.sessions.group.cta}<span aria-hidden="true">↗</span></a>
          </div>
        </article>
      </div>
    </section>

    <section class="about section-shell" id="about">
      <div class="about-image" data-reveal>
        <img src="/images/side-reach.webp" alt={t.about.imageAlt} width="1800" height="1207" loading="lazy" />
        <div class="mini-mark" aria-hidden="true"><span></span></div>
      </div>
      <div class="about-copy" data-reveal>
        <p class="eyebrow">{t.about.eyebrow}</p>
        <h2>{t.about.title}</h2>
        <p class="about-credential">{t.about.credential}</p>
        <p class="large-copy">{t.about.body}</p>
        <p class="about-details">{t.about.details}</p>
        <blockquote>{t.about.quote}</blockquote>
      </div>
    </section>

    <section class="gallery section-shell" aria-label={t.gallery.label}>
      <p class="marquee-label"><span>{t.gallery.label}</span><span aria-hidden="true">✦</span><span>{t.gallery.label}</span></p>
      <div class="gallery-grid">
        <img src="/images/teaser.webp" alt={t.gallery.alts[0]} width="1800" height="1207" loading="lazy" data-reveal />
        <img src="/images/shoulder-bridge.webp" alt={t.gallery.alts[1]} width="1800" height="1208" loading="lazy" data-reveal />
        <img src="/images/boat-pose.webp" alt={t.gallery.alts[2]} width="1800" height="1208" loading="lazy" data-reveal />
      </div>
    </section>

    <section class="booking-cta section-shell" data-reveal>
      <div class="booking-orbit" aria-hidden="true"><span></span></div>
      <p class="eyebrow">{t.booking.eyebrow}</p>
      <h2>{t.booking.title}</h2>
      <p>{t.booking.body}</p>
      <a class="button button--light" href={bookHref}>{t.booking.cta}<span aria-hidden="true">↗</span></a>
      <small>{t.booking.note}</small>
    </section>

    <section class="faq section-shell" id="faq">
      <div class="faq-heading" data-reveal><p class="eyebrow">{t.faq.eyebrow}</p><h2>{t.faq.title}</h2></div>
      <div class="faq-list" data-reveal>
        {t.faq.items.map((item, index) => (
          <details open={index === 0}>
            <summary><span>{item.q}</span><i aria-hidden="true"></i></summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </section>
  </main>
  <SiteFooter locale={locale} t={t} />
</SiteLayout>
